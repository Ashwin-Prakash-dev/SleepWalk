# Supabase project credentials (Project Settings -> API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-service-role-or-anon-key

# Direct Postgres connection string, used only to apply schema.sql via psql
# (Project Settings -> Database -> Connection string)
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# Used by embeddings.py to generate 1536-dim vectors (text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Used by llm_service.py for extraction + inference (Groq, llama-3.3-70b-versatile)
GROQ_API_KEY=gsk_...

# Used by ingest_from_newsapi() (https://newsapi.org/v2/everything)
NEWSAPI_KEY=...
