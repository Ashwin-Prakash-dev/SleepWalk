# Supabase project credentials (Project Settings -> API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-service-role-or-anon-key

# Direct Postgres connection string, used only to apply schema.sql via psql
# (Project Settings -> Database -> Connection string)
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# embeddings.py now runs a LOCAL model (sentence-transformers all-MiniLM-L6-v2),
# so no embedding API key is required. OPENAI_API_KEY is unused; kept for reference.
# OPENAI_API_KEY=sk-...

# llm_service.py LLM backends. Groq is primary; Gemini is the failover that
# absorbs overflow when Groq hits its daily token cap.
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=...

# Used by ingest_from_newsapi() (https://newsapi.org/v2/everything)
NEWSAPI_KEY=...
